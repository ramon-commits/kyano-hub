# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/gmail/callback

# Anthropic
ANTHROPIC_API_KEY=

# Encryption (genereer met: openssl rand -hex 32)
ENCRYPTION_KEY=

# Unipile (WhatsApp, Instagram, LinkedIn)
UNIPILE_API_KEY=
UNIPILE_DSN=

# Asana (FitAid taken → to-do inbox)
# Personal Access Token: https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=
# Project-GID uit de Asana project-URL (app.asana.com/0/<GID>/list)
ASANA_PROJECT_ID=
# Optioneel: komma-gescheiden assignee-emails die gesynced worden (leeg = 'ramon'/'dach')
ASANA_ASSIGNEE_EMAILS=
# Optioneel deadline-venster in dagen (leeg = alle taken, incl. achterstallige)
ASANA_DUE_WITHIN_DAYS=

# Server
PORT=3001
NODE_ENV=development
